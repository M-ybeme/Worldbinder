# Copy to .env and adjust as needed. Local defaults match infrastructure/compose/docker-compose.yml.

# --- Local infrastructure (docker compose) ---
POSTGRES_USER=worldbinder
POSTGRES_PASSWORD=worldbinder
POSTGRES_DB=worldbinder
POSTGRES_PORT=5432

REDIS_PORT=6379

MINIO_ROOT_USER=worldbinder
MINIO_ROOT_PASSWORD=worldbinder-dev-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# --- apps/api ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
DATABASE_URL=postgres://worldbinder:worldbinder@localhost:5432/worldbinder
REDIS_URL=redis://localhost:6379

# Auth — generate a real secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-random-32-byte-hex-string
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_COOKIE_NAME=worldbinder_refresh
FRONTEND_URL=http://localhost:5173

# Mail — Mailpit locally (see infrastructure/compose/docker-compose.yml); swap for a real
# provider's SMTP credentials in production.
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
MAIL_FROM=Worldbinder <noreply@worldbinder.local>

# Object storage — MinIO locally (same credentials as MINIO_ROOT_USER/PASSWORD
# above, distinct var names since apps/api and apps/worker both read these
# directly); swap for Cloudflare R2 or AWS S3 credentials in production.
STORAGE_ENDPOINT=http://127.0.0.1:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=worldbinder-dev
STORAGE_ACCESS_KEY_ID=worldbinder
STORAGE_SECRET_ACCESS_KEY=worldbinder-dev-secret
STORAGE_FORCE_PATH_STYLE=true

# --- apps/web ---
VITE_API_URL=http://localhost:3000
