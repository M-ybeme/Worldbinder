{
  "name": "@worldbinder/worker",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests --exclude \"**/*.integration.spec.ts\"",
    "test:integration": "dotenv -e ../../.env -- vitest run integration.spec --passWithNoTests",
    "load-test:export-import": "dotenv -e ../../.env -- tsx src/load-test/export-import-benchmark.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@worldbinder/config": "workspace:*",
    "@worldbinder/contracts": "workspace:*",
    "@worldbinder/validation": "workspace:*",
    "adm-zip": "^0.6.0",
    "bullmq": "^5.80.2",
    "image-size": "^2.0.2",
    "ioredis": "^5.4.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "@worldbinder/eslint-config": "workspace:*",
    "@worldbinder/tsconfig": "workspace:*",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.18.0",
    "globals": "^17.0.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.0"
  }
}
