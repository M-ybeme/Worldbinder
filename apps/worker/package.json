  },
  "devDependencies": {
    "@worldbinder/eslint-config": "workspace:*",
    "@worldbinder/tsconfig": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.18.0",
    "globals": "^17.0.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.0"
  }
